// Prisma schema do MMORPG Idle Zumbi
// MVP refatorado: atributos primários oficiais + mapas/submapas +
// combate automático idle + consumíveis de cura + configuração automática de poção +
// crafting + gathering idle + soft delete de personagens + avatar do personagem +
// histórico curto de eventos do auto-combate em tempo real +
// progressão de proficiências de gathering por personagem +
// coleta automática acumulada por sessão de gathering.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  ADMIN
}

enum CharacterStatus {
  ACTIVE
  DEAD
  BLOCKED
  DELETED
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum ItemSlot {
  MAIN_HAND
  OFF_HAND
  HEAD
  ARMOR
  PANTS
  BOOTS
  MATERIAL
  CONSUMABLE
}

enum InventoryItemType {
  EQUIPMENT
  MATERIAL
  CONSUMABLE
}

enum CombatStatus {
  IN_PROGRESS
  PLAYER_WIN
  PLAYER_LOSE
  CANCELLED
}

enum CombatActor {
  PLAYER
  MOB
  SYSTEM
}

enum AutoCombatSessionStatus {
  ACTIVE
  FINISHED
  STOPPED
  DEFEATED
}

enum MaterialOrigin {
  DESMANCHE
  COLETA
  CONTENCAO
  ARSENAL
  PATRULHA
  TECNOVARREDURA
  DROP_MOBS
}

enum ActivityStatus {
  ACTIVE
  STOPPED
  COMPLETED
}

enum CraftIngredientRole {
  MAIN_COMPONENT
  SHARED_MATERIAL
  RARE_MOB_DROP
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(PLAYER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characters Character[]

  @@map("users")
}

model GameClass {
  id          String @id @default(uuid())
  name        String @unique
  description String

  baseStrength  Int @default(1)
  baseVitality  Int @default(1)
  baseAgility   Int @default(1)
  basePrecision Int @default(1)
  baseTechnique Int @default(1)
  baseWillpower Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characters Character[]
  items      Item[]

  @@map("game_classes")
}

model GameMap {
  id          String  @id @default(uuid())
  name        String  @unique
  tier        Int
  minLevel    Int     @default(1)
  maxLevel    Int     @default(10)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characters        Character[]
  mobs              Mob[]
  items             Item[]
  subMaps           SubMap[]
  gatheringSessions GatheringSession[]

  @@index([tier])
  @@index([minLevel, maxLevel])
  @@map("game_maps")
}

model SubMap {
  id          String  @id @default(uuid())
  name        String
  description String?

  tier     Int
  minLevel Int
  maxLevel Int

  mapId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  map GameMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  encounters         SubMapEncounter[]
  autoCombatSessions AutoCombatSession[]

  @@unique([mapId, name])
  @@index([mapId])
  @@index([tier])
  @@index([minLevel, maxLevel])
  @@map("sub_maps")
}

model SubMapEncounter {
  id String @id @default(uuid())

  subMapId String
  mobId    String

  weight Int @default(100)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subMap SubMap @relation(fields: [subMapId], references: [id], onDelete: Cascade)
  mob    Mob    @relation(fields: [mobId], references: [id], onDelete: Cascade)

  @@unique([subMapId, mobId])
  @@index([subMapId])
  @@index([mobId])
  @@map("sub_map_encounters")
}

model Character {
  id     String          @id @default(uuid())
  name   String
  status CharacterStatus @default(ACTIVE)

  level Int @default(1)
  xp    Int @default(0)

  currentHp Int?
  maxHp     Int?

  avatarKey String?

  userId  String
  classId String
  mapId   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  class GameClass @relation(fields: [classId], references: [id])
  map   GameMap?  @relation(fields: [mapId], references: [id])

  inventoryItems          InventoryItem[]
  equipment               Equipment?
  potionConfig            CharacterPotionConfig?
  combats                 Combat[]
  autoCombatSessions      AutoCombatSession[]
  autoCombatSessionEvents AutoCombatSessionEvent[]
  gatheringSessions       GatheringSession[]

  gatheringSkills CharacterGatheringSkill[]

  @@unique([userId, name])
  @@index([userId])
  @@index([classId])
  @@index([mapId])
  @@index([status])
  @@index([level])
  @@index([avatarKey])
  @@index([deletedAt])
  @@index([userId, status])
  @@map("characters")
}

model CharacterGatheringSkill {
  id String @id @default(uuid())

  characterId String
  origin      MaterialOrigin

  level   Int @default(1)
  xp      Int @default(0)
  totalXp Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, origin])
  @@index([characterId])
  @@index([origin])
  @@index([level])
  @@index([characterId, level])
  @@map("character_gathering_skills")
}

model Mob {
  id          String  @id @default(uuid())
  name        String
  description String?

  level    Int
  tier     Int
  hp       Int
  attack   Int
  defense  Int
  speed    Int
  xpReward Int

  mapId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  map     GameMap   @relation(fields: [mapId], references: [id], onDelete: Cascade)
  combats Combat[]
  drops   MobDrop[]

  subMapEncounters    SubMapEncounter[]
  autoCombatSummaries AutoCombatSessionMobSummary[]

  currentAutoCombatSessions AutoCombatSession[] @relation("AutoCombatCurrentMob")

  @@index([mapId])
  @@index([tier])
  @@index([level])
  @@map("mobs")
}

model Item {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  tier   Int
  rarity Rarity
  slot   ItemSlot

  family String

  classId String?
  mapId   String?

  slug           String?         @unique
  materialOrigin MaterialOrigin?
  materialSlot   ItemSlot?

  isGatheringMaterial Boolean @default(false)

  requiredGatheringLevel   Int  @default(1)
  gatheringXpPerUnit       Int  @default(1)
  baseGatheringRatePerHour Int?

  strengthBonus  Int @default(0)
  vitalityBonus  Int @default(0)
  agilityBonus   Int @default(0)
  precisionBonus Int @default(0)
  techniqueBonus Int @default(0)
  willpowerBonus Int @default(0)

  healFlat          Int     @default(0)
  healPercent       Int     @default(0)
  usableInCombat    Boolean @default(false)
  usableOutOfCombat Boolean @default(false)

  minTier Int?
  maxTier Int?

  isCraftable Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class GameClass? @relation(fields: [classId], references: [id])
  map   GameMap?   @relation(fields: [mapId], references: [id])

  inventoryItems InventoryItem[]

  mainHandUsers Equipment[] @relation("MainHandItem")
  offHandUsers  Equipment[] @relation("OffHandItem")
  headUsers     Equipment[] @relation("HeadItem")
  armorUsers    Equipment[] @relation("ArmorItem")
  pantsUsers    Equipment[] @relation("PantsItem")
  bootsUsers    Equipment[] @relation("BootsItem")

  mobDrops        MobDrop[]
  autoCombatLoots AutoCombatSessionLoot[]

  potionConfigs CharacterPotionConfig[] @relation("PotionConfigItem")

  craftingRecipeOutput CraftingRecipe?      @relation("CraftingRecipeOutput")
  craftingIngredients  CraftingIngredient[] @relation("CraftingIngredientItem")

  gatheringTargetSessions GatheringSession[] @relation("GatheringTargetMaterial")

  @@index([classId])
  @@index([mapId])
  @@index([tier])
  @@index([slot])
  @@index([rarity])
  @@index([materialOrigin])
  @@index([materialSlot])
  @@index([isGatheringMaterial])
  @@index([materialOrigin, materialSlot])
  @@index([materialOrigin, requiredGatheringLevel])
  @@index([requiredGatheringLevel])
  @@index([baseGatheringRatePerHour])
  @@index([isCraftable])
  @@index([minTier, maxTier])
  @@map("items")
}

model CraftingRecipe {
  id String @id @default(uuid())

  outputItemId String @unique
  outputItem   Item   @relation("CraftingRecipeOutput", fields: [outputItemId], references: [id], onDelete: Cascade)

  tier     Int
  isActive Boolean @default(true)

  outputQuantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingredients CraftingIngredient[]

  @@index([tier])
  @@index([isActive])
  @@map("crafting_recipes")
}

model CraftingIngredient {
  id String @id @default(uuid())

  recipeId String
  itemId   String

  quantity Int

  role   CraftIngredientRole
  origin MaterialOrigin

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipe CraftingRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  item   Item           @relation("CraftingIngredientItem", fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([recipeId, itemId])
  @@index([recipeId])
  @@index([itemId])
  @@index([origin])
  @@index([role])
  @@map("crafting_ingredients")
}

model GatheringSession {
  id String @id @default(uuid())

  characterId String
  mapId       String

  origin MaterialOrigin

  targetMaterialId String

  status ActivityStatus @default(ACTIVE)

  startedAt      DateTime @default(now())
  lastResolvedAt DateTime @default(now())

  progressRemainder Float @default(0)

  // Total acumulado automaticamente durante esta sessão.
  // collectedQuantity = quantidade total do material enviada ao inventário.
  // collectedXp = XP total de proficiência gerado pela sessão.
  collectedQuantity Int @default(0)
  collectedXp       Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  map            GameMap   @relation(fields: [mapId], references: [id], onDelete: Cascade)
  targetMaterial Item      @relation("GatheringTargetMaterial", fields: [targetMaterialId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([mapId])
  @@index([targetMaterialId])
  @@index([origin])
  @@index([status])
  @@index([characterId, status])
  @@index([startedAt])
  @@index([collectedQuantity])
  @@index([collectedXp])
  @@map("gathering_sessions")
}

model InventoryItem {
  id String @id @default(uuid())

  characterId String
  itemId      String

  type     InventoryItemType
  quantity Int               @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([characterId, itemId])
  @@index([characterId])
  @@index([itemId])
  @@index([type])
  @@map("inventory_items")
}

model Equipment {
  id String @id @default(uuid())

  characterId String @unique

  mainHandId String?
  offHandId  String?
  headId     String?
  armorId    String?
  pantsId    String?
  bootsId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  mainHand Item? @relation("MainHandItem", fields: [mainHandId], references: [id])
  offHand  Item? @relation("OffHandItem", fields: [offHandId], references: [id])
  head     Item? @relation("HeadItem", fields: [headId], references: [id])
  armor    Item? @relation("ArmorItem", fields: [armorId], references: [id])
  pants    Item? @relation("PantsItem", fields: [pantsId], references: [id])
  boots    Item? @relation("BootsItem", fields: [bootsId], references: [id])

  @@index([mainHandId])
  @@index([offHandId])
  @@index([headId])
  @@index([armorId])
  @@index([pantsId])
  @@index([bootsId])
  @@map("equipment")
}

model CharacterPotionConfig {
  id String @id @default(uuid())

  characterId  String  @unique
  potionItemId String?

  enabled Boolean @default(false)

  hpThresholdPercent Int @default(35)

  useInManualCombat Boolean @default(true)
  useInAutoCombat   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character  Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  potionItem Item?     @relation("PotionConfigItem", fields: [potionItemId], references: [id], onDelete: SetNull)

  @@index([characterId])
  @@index([potionItemId])
  @@index([enabled])
  @@map("character_potion_configs")
}

model MobDrop {
  id String @id @default(uuid())

  mobId  String
  itemId String

  dropChance Int @default(100)

  minQuantity Int @default(1)
  maxQuantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mob  Mob  @relation(fields: [mobId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([mobId, itemId])
  @@index([mobId])
  @@index([itemId])
  @@map("mob_drops")
}

model Combat {
  id String @id @default(uuid())

  characterId String
  mobId       String

  status CombatStatus @default(IN_PROGRESS)

  playerStartHp Int
  playerEndHp   Int?

  mobStartHp Int
  mobEndHp   Int?

  xpGained Int @default(0)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  mob       Mob       @relation(fields: [mobId], references: [id])

  logs CombatLog[]

  @@index([characterId])
  @@index([mobId])
  @@index([status])
  @@index([startedAt])
  @@map("combats")
}

model CombatLog {
  id String @id @default(uuid())

  combatId String

  round   Int
  actor   CombatActor
  message String

  damage Int @default(0)

  createdAt DateTime @default(now())

  combat Combat @relation(fields: [combatId], references: [id], onDelete: Cascade)

  @@index([combatId])
  @@index([round])
  @@map("combat_logs")
}

model AutoCombatSession {
  id String @id @default(uuid())

  characterId String
  subMapId    String

  status AutoCombatSessionStatus @default(ACTIVE)

  startedAt       DateTime @default(now())
  endsAt          DateTime
  lastProcessedAt DateTime

  finishedAt DateTime?

  durationSeconds Int @default(21600)

  roundDurationSeconds Int @default(1)

  totalCombatsResolved Int @default(0)
  totalRoundsResolved  Int @default(0)
  totalXpGained        Int @default(0)
  totalPotionsUsed     Int @default(0)

  currentMobId       String?
  currentMobHp       Int?
  currentMobMaxHp    Int?
  currentRound       Int     @default(0)
  currentCombatIndex Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  subMap    SubMap    @relation(fields: [subMapId], references: [id])

  currentMob Mob? @relation("AutoCombatCurrentMob", fields: [currentMobId], references: [id], onDelete: SetNull)

  loots        AutoCombatSessionLoot[]
  mobSummaries AutoCombatSessionMobSummary[]
  events       AutoCombatSessionEvent[]

  @@index([characterId])
  @@index([subMapId])
  @@index([currentMobId])
  @@index([status])
  @@index([characterId, status])
  @@index([startedAt])
  @@index([endsAt])
  @@map("auto_combat_sessions")
}

model AutoCombatSessionLoot {
  id String @id @default(uuid())

  sessionId String
  itemId    String

  quantity Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session AutoCombatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item    Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([sessionId, itemId])
  @@index([sessionId])
  @@index([itemId])
  @@map("auto_combat_session_loots")
}

model AutoCombatSessionMobSummary {
  id String @id @default(uuid())

  sessionId String
  mobId     String

  kills    Int @default(0)
  xpGained Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session AutoCombatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  mob     Mob               @relation(fields: [mobId], references: [id], onDelete: Cascade)

  @@unique([sessionId, mobId])
  @@index([sessionId])
  @@index([mobId])
  @@map("auto_combat_session_mob_summaries")
}

model AutoCombatSessionEvent {
  id String @id @default(uuid())

  sessionId   String
  characterId String

  type String

  sequence Int

  payloadJson Json

  createdAt DateTime @default(now())

  session   AutoCombatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  character Character         @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sequence])
  @@index([sessionId])
  @@index([characterId])
  @@index([type])
  @@index([createdAt])
  @@index([sessionId, createdAt])
  @@index([characterId, createdAt])
  @@map("auto_combat_session_events")
}
