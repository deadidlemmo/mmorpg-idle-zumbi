// Prisma schema do MMORPG Idle Zumbi
// MVP refatorado: atributos primários oficiais + mapas/submapas +
// combate automático idle + consumíveis de cura + configuração automática de poção +
// crafting + gathering idle + soft delete de personagens + avatar do personagem +
// histórico curto de eventos do auto-combate em tempo real +
// progressão de proficiências de gathering por personagem +
// coleta automática acumulada por sessão de gathering.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  ADMIN
}

enum CharacterStatus {
  ACTIVE
  DEAD
  BLOCKED
  DELETED
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum ItemSlot {
  MAIN_HAND
  OFF_HAND
  HEAD
  ARMOR
  PANTS
  BOOTS
  MATERIAL
  CONSUMABLE
}

enum InventoryItemType {
  EQUIPMENT
  MATERIAL
  CONSUMABLE
}

enum CombatStatus {
  IN_PROGRESS
  PLAYER_WIN
  PLAYER_LOSE
  CANCELLED
}

enum CombatActor {
  PLAYER
  MOB
  SYSTEM
}

enum AutoCombatSessionStatus {
  ACTIVE
  FINISHED
  STOPPED
  DEFEATED
}

enum MaterialOrigin {
  DESMANCHE
  COLETA
  CONTENCAO
  ARSENAL
  PATRULHA
  TECNOVARREDURA
  DROP_MOBS
}

enum ActivityStatus {
  ACTIVE
  STOPPED
  COMPLETED
}

enum CraftIngredientRole {
  MAIN_COMPONENT
  SHARED_MATERIAL
  RARE_MOB_DROP
}

enum IncursionDifficulty {
  LOW
  MEDIUM
  HIGH
  EXTREME
}

enum IncursionRewardType {
  XP
  GOLD
  MATERIAL
  CONSUMABLE
  EQUIPMENT
  ITEM
}

enum IncursionSessionStatus {
  ACTIVE
  COMPLETED
  CLAIMED
  FAILED
  CANCELLED
}

enum WorldBossEventStatus {
  SCHEDULED
  LOBBY_OPEN
  ACTIVE
  DEFEATED
  EXPIRED
  REWARDED
  CANCELLED
}

enum WorldBossRewardType {
  XP
  GOLD
  MATERIAL
  CONSUMABLE
  EQUIPMENT
  ITEM
  PET_EGG
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(PLAYER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characters Character[]

  @@map("users")
}

model GameClass {
  id          String @id @default(uuid())
  name        String @unique
  description String

  baseStrength  Int @default(1)
  baseVitality  Int @default(1)
  baseAgility   Int @default(1)
  basePrecision Int @default(1)
  baseTechnique Int @default(1)
  baseWillpower Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characters Character[]
  items      Item[]

  @@map("game_classes")
}

model GameMap {
  id          String  @id @default(uuid())
  name        String  @unique
  tier        Int
  minLevel    Int     @default(1)
  maxLevel    Int     @default(10)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characters        Character[]
  mobs              Mob[]
  items             Item[]
  subMaps           SubMap[]
  gatheringSessions GatheringSession[]
  incursions        Incursion[]
  worldBosses       WorldBoss[]
  worldBossEvents   WorldBossEvent[]

  @@index([tier])
  @@index([minLevel, maxLevel])
  @@map("game_maps")
}

model SubMap {
  id          String  @id @default(uuid())
  name        String
  description String?

  tier     Int
  minLevel Int
  maxLevel Int

  mapId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  map GameMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  encounters         SubMapEncounter[]
  autoCombatSessions AutoCombatSession[]

  @@unique([mapId, name])
  @@index([mapId])
  @@index([tier])
  @@index([minLevel, maxLevel])
  @@map("sub_maps")
}

model SubMapEncounter {
  id String @id @default(uuid())

  subMapId String
  mobId    String

  weight Int @default(100)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subMap SubMap @relation(fields: [subMapId], references: [id], onDelete: Cascade)
  mob    Mob    @relation(fields: [mobId], references: [id], onDelete: Cascade)

  @@unique([subMapId, mobId])
  @@index([subMapId])
  @@index([mobId])
  @@map("sub_map_encounters")
}

model Character {
  id     String          @id @default(uuid())
  name   String
  status CharacterStatus @default(ACTIVE)

  level Int @default(1)
  xp    Int @default(0)

  gold Int @default(0)
  cash Int @default(0)

  currentHp Int?
  maxHp     Int?

  avatarKey String?

  userId  String
  classId String
  mapId   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  class GameClass @relation(fields: [classId], references: [id])
  map   GameMap?  @relation(fields: [mapId], references: [id])

  inventoryItems          InventoryItem[]
  bankItems               BankItem[]
  equipment               Equipment?
  potionConfig            CharacterPotionConfig?
  combats                 Combat[]
  autoCombatSessions      AutoCombatSession[]
  autoCombatSessionEvents AutoCombatSessionEvent[]
  gatheringSessions       GatheringSession[]
  craftingSessions        CraftingSession[]
  incursionSessions       CharacterIncursionSession[]
  worldBossParticipations WorldBossParticipant[]

  gatheringSkills CharacterGatheringSkill[]
  craftingSkill   CharacterCraftingSkill?

  @@unique([userId, name])
  @@index([userId])
  @@index([classId])
  @@index([mapId])
  @@index([status])
  @@index([level])
  @@index([avatarKey])
  @@index([deletedAt])
  @@index([userId, status])
  @@map("characters")
}

model CharacterGatheringSkill {
  id String @id @default(uuid())

  characterId String
  origin      MaterialOrigin

  level   Int @default(1)
  xp      Int @default(0)
  totalXp Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, origin])
  @@index([characterId])
  @@index([origin])
  @@index([level])
  @@index([characterId, level])
  @@map("character_gathering_skills")
}

model CharacterCraftingSkill {
  id String @id @default(uuid())

  characterId String @unique

  level   Int @default(1)
  xp      Int @default(0)
  totalXp Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([level])
  @@map("character_crafting_skills")
}

model Mob {
  id          String  @id @default(uuid())
  name        String
  description String?

  level    Int
  tier     Int
  hp       Int
  attack   Int
  defense  Int
  speed    Int
  xpReward Int

  mapId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  map     GameMap   @relation(fields: [mapId], references: [id], onDelete: Cascade)
  combats Combat[]
  drops   MobDrop[]

  subMapEncounters    SubMapEncounter[]
  autoCombatSummaries AutoCombatSessionMobSummary[]

  currentAutoCombatSessions AutoCombatSession[] @relation("AutoCombatCurrentMob")

  @@index([mapId])
  @@index([tier])
  @@index([level])
  @@map("mobs")
}

model Item {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  tier   Int
  rarity Rarity
  slot   ItemSlot

  family String

  classId String?
  mapId   String?

  slug           String?         @unique
  materialOrigin MaterialOrigin?
  materialSlot   ItemSlot?

  isGatheringMaterial Boolean @default(false)

  requiredGatheringLevel   Int  @default(1)
  gatheringXpPerUnit       Int  @default(1)
  baseGatheringRatePerHour Int?

  strengthBonus  Int @default(0)
  vitalityBonus  Int @default(0)
  agilityBonus   Int @default(0)
  precisionBonus Int @default(0)
  techniqueBonus Int @default(0)
  willpowerBonus Int @default(0)

  healFlat          Int     @default(0)
  healPercent       Int     @default(0)
  usableInCombat    Boolean @default(false)
  usableOutOfCombat Boolean @default(false)

  minTier Int?
  maxTier Int?

  isCraftable Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class GameClass? @relation(fields: [classId], references: [id])
  map   GameMap?   @relation(fields: [mapId], references: [id])

  inventoryItems InventoryItem[]
  bankItems      BankItem[]

  mainHandUsers Equipment[] @relation("MainHandItem")
  offHandUsers  Equipment[] @relation("OffHandItem")
  headUsers     Equipment[] @relation("HeadItem")
  armorUsers    Equipment[] @relation("ArmorItem")
  pantsUsers    Equipment[] @relation("PantsItem")
  bootsUsers    Equipment[] @relation("BootsItem")

  mobDrops                MobDrop[]
  autoCombatLoots         AutoCombatSessionLoot[]
  incursionLootTables     IncursionLootTable[]
  incursionSessionRewards IncursionSessionReward[]
  worldBossRewards        WorldBossReward[]
  worldBossGrantedRewards WorldBossGrantedReward[]

  potionConfigs CharacterPotionConfig[] @relation("PotionConfigItem")

  craftingRecipeOutput   CraftingRecipe?      @relation("CraftingRecipeOutput")
  craftingIngredients    CraftingIngredient[] @relation("CraftingIngredientItem")
  craftingSessionOutputs CraftingSession[]    @relation("CraftingSessionOutputItem")

  gatheringTargetSessions GatheringSession[] @relation("GatheringTargetMaterial")

  @@index([classId])
  @@index([mapId])
  @@index([tier])
  @@index([slot])
  @@index([rarity])
  @@index([materialOrigin])
  @@index([materialSlot])
  @@index([isGatheringMaterial])
  @@index([materialOrigin, materialSlot])
  @@index([materialOrigin, requiredGatheringLevel])
  @@index([requiredGatheringLevel])
  @@index([baseGatheringRatePerHour])
  @@index([isCraftable])
  @@index([minTier, maxTier])
  @@map("items")
}

model CraftingRecipe {
  id String @id @default(uuid())

  outputItemId String @unique
  outputItem   Item   @relation("CraftingRecipeOutput", fields: [outputItemId], references: [id], onDelete: Cascade)

  tier     Int
  isActive Boolean @default(true)

  outputQuantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingredients CraftingIngredient[]
  sessions    CraftingSession[]

  @@index([tier])
  @@index([isActive])
  @@map("crafting_recipes")
}

model CraftingSession {
  id String @id @default(uuid())

  characterId  String
  recipeId     String
  outputItemId String

  status ActivityStatus @default(ACTIVE)

  quantity         Int
  outputQuantity   Int
  craftingXpGained Int
  durationSeconds  Int

  startedAt   DateTime  @default(now())
  completesAt DateTime
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character  Character      @relation(fields: [characterId], references: [id], onDelete: Cascade)
  recipe     CraftingRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  outputItem Item           @relation("CraftingSessionOutputItem", fields: [outputItemId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([recipeId])
  @@index([outputItemId])
  @@index([status])
  @@index([characterId, status])
  @@index([completesAt])
  @@map("crafting_sessions")
}

model CraftingIngredient {
  id String @id @default(uuid())

  recipeId String
  itemId   String

  quantity Int

  role   CraftIngredientRole
  origin MaterialOrigin

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipe CraftingRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  item   Item           @relation("CraftingIngredientItem", fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([recipeId, itemId])
  @@index([recipeId])
  @@index([itemId])
  @@index([origin])
  @@index([role])
  @@map("crafting_ingredients")
}

model GatheringSession {
  id String @id @default(uuid())

  characterId String
  mapId       String

  origin MaterialOrigin

  targetMaterialId String

  status ActivityStatus @default(ACTIVE)

  startedAt      DateTime @default(now())
  lastResolvedAt DateTime @default(now())

  progressRemainder Float @default(0)

  // Total acumulado automaticamente durante esta sessão.
  // collectedQuantity = quantidade total do material enviada ao inventário.
  // collectedXp = XP total de proficiência gerado pela sessão.
  collectedQuantity Int @default(0)
  collectedXp       Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  map            GameMap   @relation(fields: [mapId], references: [id], onDelete: Cascade)
  targetMaterial Item      @relation("GatheringTargetMaterial", fields: [targetMaterialId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([mapId])
  @@index([targetMaterialId])
  @@index([origin])
  @@index([status])
  @@index([characterId, status])
  @@index([startedAt])
  @@index([collectedQuantity])
  @@index([collectedXp])
  @@map("gathering_sessions")
}

model InventoryItem {
  id String @id @default(uuid())

  characterId String
  itemId      String

  type     InventoryItemType
  quantity Int               @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([characterId, itemId])
  @@index([characterId])
  @@index([itemId])
  @@index([type])
  @@map("inventory_items")
}

model BankItem {
  id String @id @default(uuid())

  characterId String
  itemId      String

  type     InventoryItemType
  quantity Int               @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([characterId, itemId])
  @@index([characterId])
  @@index([itemId])
  @@index([type])
  @@map("bank_items")
}

model Equipment {
  id String @id @default(uuid())

  characterId String @unique

  mainHandId String?
  offHandId  String?
  headId     String?
  armorId    String?
  pantsId    String?
  bootsId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  mainHand Item? @relation("MainHandItem", fields: [mainHandId], references: [id])
  offHand  Item? @relation("OffHandItem", fields: [offHandId], references: [id])
  head     Item? @relation("HeadItem", fields: [headId], references: [id])
  armor    Item? @relation("ArmorItem", fields: [armorId], references: [id])
  pants    Item? @relation("PantsItem", fields: [pantsId], references: [id])
  boots    Item? @relation("BootsItem", fields: [bootsId], references: [id])

  @@index([mainHandId])
  @@index([offHandId])
  @@index([headId])
  @@index([armorId])
  @@index([pantsId])
  @@index([bootsId])
  @@map("equipment")
}

model CharacterPotionConfig {
  id String @id @default(uuid())

  characterId  String  @unique
  potionItemId String?

  enabled Boolean @default(false)

  hpThresholdPercent Int @default(35)

  useInManualCombat Boolean @default(true)
  useInAutoCombat   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character  Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  potionItem Item?     @relation("PotionConfigItem", fields: [potionItemId], references: [id], onDelete: SetNull)

  @@index([characterId])
  @@index([potionItemId])
  @@index([enabled])
  @@map("character_potion_configs")
}

model MobDrop {
  id String @id @default(uuid())

  mobId  String
  itemId String

  dropChance Int @default(100)

  minQuantity Int @default(1)
  maxQuantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mob  Mob  @relation(fields: [mobId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([mobId, itemId])
  @@index([mobId])
  @@index([itemId])
  @@map("mob_drops")
}

model Combat {
  id String @id @default(uuid())

  characterId String
  mobId       String

  status CombatStatus @default(IN_PROGRESS)

  playerStartHp Int
  playerEndHp   Int?

  mobStartHp Int
  mobEndHp   Int?

  xpGained Int @default(0)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  mob       Mob       @relation(fields: [mobId], references: [id])

  logs CombatLog[]

  @@index([characterId])
  @@index([mobId])
  @@index([status])
  @@index([startedAt])
  @@map("combats")
}

model CombatLog {
  id String @id @default(uuid())

  combatId String

  round   Int
  actor   CombatActor
  message String

  damage Int @default(0)

  createdAt DateTime @default(now())

  combat Combat @relation(fields: [combatId], references: [id], onDelete: Cascade)

  @@index([combatId])
  @@index([round])
  @@map("combat_logs")
}

model AutoCombatSession {
  id String @id @default(uuid())

  characterId String
  subMapId    String

  status AutoCombatSessionStatus @default(ACTIVE)

  startedAt       DateTime @default(now())
  endsAt          DateTime
  lastProcessedAt DateTime

  finishedAt DateTime?

  durationSeconds Int @default(21600)

  roundDurationSeconds Int @default(1)

  totalCombatsResolved Int @default(0)
  totalRoundsResolved  Int @default(0)
  totalXpGained        Int @default(0)
  totalPotionsUsed     Int @default(0)

  currentMobId       String?
  currentMobHp       Int?
  currentMobMaxHp    Int?
  currentRound       Int     @default(0)
  currentCombatIndex Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  subMap    SubMap    @relation(fields: [subMapId], references: [id])

  currentMob Mob? @relation("AutoCombatCurrentMob", fields: [currentMobId], references: [id], onDelete: SetNull)

  loots        AutoCombatSessionLoot[]
  mobSummaries AutoCombatSessionMobSummary[]
  events       AutoCombatSessionEvent[]

  @@index([characterId])
  @@index([subMapId])
  @@index([currentMobId])
  @@index([status])
  @@index([characterId, status])
  @@index([startedAt])
  @@index([endsAt])
  @@map("auto_combat_sessions")
}

model AutoCombatSessionLoot {
  id String @id @default(uuid())

  sessionId String
  itemId    String

  quantity Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session AutoCombatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item    Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([sessionId, itemId])
  @@index([sessionId])
  @@index([itemId])
  @@map("auto_combat_session_loots")
}

model AutoCombatSessionMobSummary {
  id String @id @default(uuid())

  sessionId String
  mobId     String

  kills    Int @default(0)
  xpGained Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session AutoCombatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  mob     Mob               @relation(fields: [mobId], references: [id], onDelete: Cascade)

  @@unique([sessionId, mobId])
  @@index([sessionId])
  @@index([mobId])
  @@map("auto_combat_session_mob_summaries")
}

model AutoCombatSessionEvent {
  id String @id @default(uuid())

  sessionId   String
  characterId String

  type String

  sequence Int

  payloadJson Json

  createdAt DateTime @default(now())

  session   AutoCombatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  character Character         @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sequence])
  @@index([sessionId])
  @@index([characterId])
  @@index([type])
  @@index([createdAt])
  @@index([sessionId, createdAt])
  @@index([characterId, createdAt])
  @@map("auto_combat_session_events")
}

model Incursion {
  id String @id @default(uuid())

  name        String
  slug        String  @unique
  description String?

  mapId String

  tier     Int
  minLevel Int
  maxLevel Int

  goldCost        Int
  durationSeconds Int

  difficulty IncursionDifficulty @default(LOW)
  riskLevel  Int                 @default(1)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  map GameMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  lootTable IncursionLootTable[]
  sessions  CharacterIncursionSession[]

  @@index([mapId])
  @@index([tier])
  @@index([minLevel, maxLevel])
  @@index([isActive])
  @@index([sortOrder])
  @@map("incursions")
}

model IncursionLootTable {
  id String @id @default(uuid())

  incursionId String
  rewardType  IncursionRewardType

  itemId String?

  chance Int @default(100)

  minQuantity Int @default(1)
  maxQuantity Int @default(1)

  guaranteed Boolean @default(false)
  rarity     Rarity?

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incursion Incursion @relation(fields: [incursionId], references: [id], onDelete: Cascade)
  item      Item?     @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([incursionId])
  @@index([rewardType])
  @@index([itemId])
  @@index([sortOrder])
  @@map("incursion_loot_tables")
}

model CharacterIncursionSession {
  id String @id @default(uuid())

  characterId String
  incursionId String

  status IncursionSessionStatus @default(ACTIVE)

  startedAt   DateTime  @default(now())
  endsAt      DateTime
  completedAt DateTime?
  claimedAt   DateTime?

  goldCostPaid Int @default(0)
  xpReward     Int @default(0)
  goldReward   Int @default(0)

  generatedRewardsJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  incursion Incursion @relation(fields: [incursionId], references: [id])

  rewards IncursionSessionReward[]

  @@index([characterId])
  @@index([incursionId])
  @@index([status])
  @@index([characterId, status])
  @@index([startedAt])
  @@index([endsAt])
  @@map("character_incursion_sessions")
}

model IncursionSessionReward {
  id String @id @default(uuid())

  sessionId String

  rewardType IncursionRewardType
  itemId     String?

  quantity Int     @default(0)
  rarity   Rarity?

  createdAt DateTime @default(now())

  session CharacterIncursionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item    Item?                     @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([rewardType])
  @@index([itemId])
  @@map("incursion_session_rewards")
}

model WorldBoss {
  id String @id @default(uuid())

  name        String
  slug        String  @unique
  description String?

  mapId String
  tier  Int

  minLevel Int
  maxLevel Int

  baseHp                  Int
  maxHp                   Int?
  hpPerParticipant        Int   @default(0)
  powerScalingFactor      Float @default(0)
  scalingFactor           Float @default(1)
  minParticipantsExpected Int   @default(1)
  maxScalingCap           Float @default(3)
  scalingWindowSeconds    Int   @default(600)

  attackPower      Int   @default(0)
  defense          Int   @default(0)
  resistance       Int   @default(0)
  mutationLevel    Int   @default(1)
  damageReduction  Float @default(0)
  enrageMultiplier Float @default(1)

  durationSeconds Int
  difficulty      String @default("NORMAL")
  riskLevel       Int    @default(1)

  minParticipationSeconds Int @default(300)
  minParticipationDamage  Int @default(1)

  imageUrl String?
  assetKey String?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  map GameMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  rewards WorldBossReward[]
  events  WorldBossEvent[]

  @@index([mapId])
  @@index([tier])
  @@index([minLevel, maxLevel])
  @@index([isActive])
  @@index([sortOrder])
  @@map("world_bosses")
}

model WorldBossEvent {
  id String @id @default(uuid())

  worldBossId String
  mapId       String
  tier        Int

  status WorldBossEventStatus @default(SCHEDULED)

  startsAt DateTime
  endsAt   DateTime

  maxHp     Int
  currentHp Int

  totalDamage      Int @default(0)
  participantCount Int @default(0)

  hpLockedAt DateTime?
  defeatedAt DateTime?
  rewardedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  worldBoss WorldBoss @relation(fields: [worldBossId], references: [id], onDelete: Cascade)
  map       GameMap   @relation(fields: [mapId], references: [id], onDelete: Cascade)

  participants WorldBossParticipant[]

  @@index([worldBossId])
  @@index([mapId])
  @@index([tier])
  @@index([status])
  @@index([startsAt])
  @@index([endsAt])
  @@map("world_boss_events")
}

model WorldBossParticipant {
  id String @id @default(uuid())

  eventId     String
  characterId String

  damageDealt         Int   @default(0)
  contributionPercent Float @default(0)

  joinedAt           DateTime  @default(now())
  lastContributionAt DateTime  @default(now())
  leftAt             DateTime?
  activeSeconds      Int       @default(0)

  rewardGranted   Boolean   @default(false)
  rewardGrantedAt DateTime?

  rank              Int?
  eligibleForReward Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     WorldBossEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  character Character      @relation(fields: [characterId], references: [id], onDelete: Cascade)

  rewards WorldBossGrantedReward[]

  @@unique([eventId, characterId])
  @@index([eventId])
  @@index([characterId])
  @@index([leftAt])
  @@index([rewardGranted])
  @@index([eligibleForReward])
  @@map("world_boss_participants")
}

model WorldBossReward {
  id String @id @default(uuid())

  worldBossId String
  rewardType  WorldBossRewardType

  itemId String?

  minQuantity Int @default(1)
  maxQuantity Int @default(1)

  chance                   Float   @default(100)
  guaranteed               Boolean @default(false)
  onlyIfDefeated           Boolean @default(false)
  requiresMinParticipation Boolean @default(true)

  minContributionPercent Float   @default(0)
  minRankPercent         Float?
  rarity                 Rarity?
  sortOrder              Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  worldBoss WorldBoss @relation(fields: [worldBossId], references: [id], onDelete: Cascade)
  item      Item?     @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([worldBossId])
  @@index([rewardType])
  @@index([itemId])
  @@index([sortOrder])
  @@map("world_boss_rewards")
}

model WorldBossGrantedReward {
  id String @id @default(uuid())

  participantId String
  itemId        String?

  rewardType WorldBossRewardType
  quantity   Int                 @default(0)
  rarity     Rarity?

  createdAt DateTime @default(now())

  participant WorldBossParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  item        Item?                @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([participantId])
  @@index([rewardType])
  @@index([itemId])
  @@map("world_boss_granted_rewards")
}
