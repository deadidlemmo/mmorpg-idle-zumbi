# PostgreSQL/Prisma.
# Docker Compose local deste repositorio:
# DATABASE_URL="postgresql://zumbi:zumbi123@localhost:5433/mmorpg_zumbi?schema=public"
DATABASE_URL="postgresql://usuario:senha@localhost:5432/nome_do_banco?schema=public"

# JWT HTTP e WebSocket.
JWT_SECRET="troque_esta_chave"

# Presente no exemplo, mas o AuthModule atual usa expiresIn: '7d' fixo.
# Confirme o codigo antes de tratar esta variavel como funcional.
JWT_EXPIRES_IN="7d"

# Redis existe no Docker Compose e nas dependencias.
# Uso funcional em backend/src nao foi identificado nesta revisao.
REDIS_HOST="localhost"
REDIS_PORT="6379"

# Porta do NestJS.
APP_PORT="3000"
