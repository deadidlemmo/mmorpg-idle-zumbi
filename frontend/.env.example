# API REST do backend.
VITE_API_URL=http://localhost:3000

# Base do Socket.IO. Se omitida, os clientes usam fallback para VITE_API_URL.
VITE_SOCKET_URL=http://localhost:3000

# Fallback legado usado por providers de gathering/crafting.
VITE_BACKEND_URL=http://localhost:3000

# Link opcional exibido pela interface quando configurado.
VITE_DISCORD_URL=

# HMR opcional do Vite para tunnel/proxy.
# VITE_HMR_PROTOCOL=ws
# VITE_HMR_CLIENT_PORT=5173
